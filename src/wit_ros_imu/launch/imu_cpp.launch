
<!-- open imu and rviz -->
<launch>

    <!-- imu cpp -->
    <node pkg="wit_ros_imu" type="wit_cpp" name="imu" output="screen">
        <param name="port"               type = "str"    value="/dev/esp_usb"/>
        <param name="baud"               type = "int"    value="230400"/>
    </node>

</launch>   
