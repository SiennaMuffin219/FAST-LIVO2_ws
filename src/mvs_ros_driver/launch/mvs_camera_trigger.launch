<launch>
  <node 
    pkg="mvs_ros_driver"
    type="grabImgWithTrigger"
    name="mvs_camera_trigger"
    args="$(find mvs_ros_driver)/config/left_camera_trigger.yaml"
    respawn="true"
    output="screen"
  >
    <env name="LD_LIBRARY_PATH" value="/opt/ros/noetic/lib:/opt/MVS/lib/64:/opt/MVS/lib/32" />
  </node>
  
  <node name="extract" pkg="image_view" type="extract_images" respawn="false" required="true" output="screen" cwd="ROS_HOME">
     <remap from="image" to="/left_camera/image"/>
   </node>
  
 <node 
    pkg="rviz"
    type="rviz"
    name="rviz"
    args="-d $(find mvs_ros_driver)/rviz_cfg/mvs_camera.rviz"
  />
      launch-prefix="gdb -ex run --args"

</launch>
